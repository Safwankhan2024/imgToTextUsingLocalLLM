# Define the local Visual Language (VL) Model API endpoint
# Expected to be an OpenAI-compatible endpoint URL
VL_API_BASE=http://127.0.0.1:8080/v1

# The name of the model being used
VL_MODEL=dummy_model_name

# Timeout in seconds for the LLM inference
LLM_TIMEOUT=120


# Django Settings
SECRET_KEY=django-insecure-your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=*

