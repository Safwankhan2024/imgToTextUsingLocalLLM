# Define the local Visual Language (VL) Model API endpoint
# Expected to be an OpenAI-compatible endpoint URL
VL_API_BASE=http://127.0.0.1:8080/v1

# The name of the model being used
VL_MODEL=dummy_model_name

# Timeout in seconds for the LLM inference
LLM_TIMEOUT=120

# Maximum tokens the model may generate per image (default 8192)
# Reasoning models (Qwen3.5, DeepSeek-R1, etc.) spend tokens on <think> blocks
# before writing the answer. If your server uses --reasoning-budget N, set this
# to at least N + expected_answer_tokens, otherwise the model hits the cap mid-think
# and returns an empty response. With --reasoning-budget 4096, 8192 is safe.
LLM_MAX_TOKENS=8192

# Set to "true" only if you want chain-of-thought reasoning (slower, rarely needed for OCR)
LLM_ENABLE_THINKING=false


# Django Settings
SECRET_KEY=django-insecure-your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=*

LLM_RETRIES=3

